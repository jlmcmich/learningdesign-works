---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';

const programs = [
	{
		years: '2025–present',
		title: 'AI Academy',
		org: 'College of Liberal Arts and Sciences, Arizona State University',
		description: 'Co-leading a faculty development program for thoughtful AI integration in teaching and research across The College.',
	},
	{
		years: '2023–2025',
		title: 'AI Tools Development Team',
		org: 'Ira A. Fulton Schools of Engineering, Arizona State University',
		description: 'Established and led a development team that produced more than thirty AI tools for instructional design and faculty support. Many are reproduced in the <a href="/ai-prompts">prompt library</a> on this site; four were adopted into ASU\'s Learning Design Suite for institution-wide distribution.',
	},
	{
		years: '2016–2023',
		title: 'SMU Libraries Internship Program',
		org: 'Southern Methodist University',
		description: 'Established and led an apprenticeship program for librarians in training. Built on Legitimate Peripheral Practitioner, Situated Learning, and Community of Practice frameworks. Interns received national recognition including the ALA Emerging Leaders Award, Kaleidoscope, and Spectrum Scholarships.',
	},
	{
		years: '2016–2023',
		title: 'First-Year Writing Information Literacy Program',
		org: 'Southern Methodist University',
		description: 'Designed the information literacy curriculum and ran the program that delivered IL instruction to every section of First-Year Writing. Included research-assignment design and the training and coordination of all instructors in the program.',
	},
];

const teaching = [
	{
		years: '2013–2016',
		title: 'INLS 502: User Education',
		org: 'University of North Carolina, School of Information and Library Science',
		description: 'Adjunct faculty appointment. Redesigned and taught the master’s-level course on user education and information literacy instruction.',
	},
	{
		years: '2013–2016',
		title: 'Master’s Theses Advised',
		org: 'UNC SILS',
		description: 'Advised eight master’s theses in instructional design and information literacy. Several were adapted into peer-reviewed publications and national conference presentations; one received UNC SILS’s Dean’s Achievement Award for Outstanding Master’s Thesis.',
	},
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Mentorship & Teaching | ${SITE_TITLE}`}
			description="Programs, courses, and apprenticeships I have designed and taught across academic libraries, instructional design, and AI integration in higher education."
		/>
	</head>
	<body>
		<Header />
		<main>
			<section class="page-head" data-reveal>
				<h1>Mentorship &amp; Teaching</h1>
				<p class="page-lede">
					I'm most energized by building initiatives and communities that begin with a need
					and grow into something others can build on.
				</p>
			</section>

			<section class="callout" data-reveal style="--reveal-delay: 80ms;">
				<div class="callout-label">National Mentorship Role</div>
				<h2>Faculty Mentor — <a href="https://www.aacu.org/event/2025-26-institute-ai-pedagogy-curriculum">AAC&amp;U Institute on AI, Pedagogy, and Curriculum</a></h2>
				<p>
					Mentor cohorts from institutions across the country in developing responsible
					AI integrations. Moderated a panel on agentic AI at the most recent convening.
				</p>
			</section>

			<section class="section">
				<header class="section-head">
					<h2>Program Development</h2>
				</header>

				<ul class="entry-list">
					{programs.map((p) => (
						<li class="entry">
							<div class="entry-year">{p.years}</div>
							<div class="entry-body">
								<h3>{p.title}</h3>
								<div class="entry-venue">{p.org}</div>
								<p class="entry-desc" set:html={p.description}></p>
							</div>
						</li>
					))}
				</ul>
			</section>

			<section class="section">
				<header class="section-head">
					<h2>Teaching</h2>
				</header>

				<ul class="entry-list">
					{teaching.map((t) => (
						<li class="entry">
							<div class="entry-year">{t.years}</div>
							<div class="entry-body">
								<h3>{t.title}</h3>
								<div class="entry-venue">{t.org}</div>
								<p class="entry-desc">{t.description}</p>
							</div>
						</li>
					))}
				</ul>
			</section>
		</main>
		<Footer />

		<style>
			.page-head {
				padding: 2.5rem 0 3rem;
				border-bottom: 1px solid var(--color-border);
				margin-bottom: 2.5rem;
			}
			.page-head h1 { margin: 0 0 1rem; }
			.page-lede {
				font-size: 1.1rem;
				line-height: 1.65;
				color: var(--color-text-muted);
				max-width: 70ch;
				margin: 0;
			}

			.callout {
				padding: 1.5rem 1.75rem;
				background: var(--color-bg-subtle);
				border: 1px solid var(--color-border);
				border-left: 3px solid var(--color-accent);
				border-radius: var(--radius);
				margin-bottom: 4rem;
				max-width: 70ch;
			}
			.callout-label {
				font-family: var(--font-mono);
				font-size: 0.74rem;
				color: var(--color-text-faint);
				font-weight: 500;
				margin-bottom: 0.6rem;
			}
			.callout h2 {
				font-size: 1.15rem;
				font-weight: 600;
				margin: 0 0 0.65rem;
				letter-spacing: -0.012em;
			}
			.callout p {
				margin: 0;
				font-size: 0.95rem;
				line-height: 1.6;
				color: var(--color-text-muted);
			}

			.section { margin-bottom: 4rem; }
			.section-head {
				display: flex;
				justify-content: space-between;
				align-items: baseline;
				gap: 1rem;
				margin-bottom: 1.5rem;
				padding-bottom: 0.75rem;
				border-bottom: 1px solid var(--color-border);
			}
			.section-head h2 {
				margin: 0;
				font-size: 1.45rem;
				font-weight: 600;
				letter-spacing: -0.018em;
			}

			.entry-list {
				list-style: none;
				padding: 0;
				margin: 0;
			}
			.entry {
				display: grid;
				grid-template-columns: 130px 1fr;
				gap: 2rem;
				padding: 1.4rem 0;
				border-bottom: 1px solid var(--color-border-soft);
			}
			.entry:last-child { border-bottom: none; }
			.entry-year {
				font-family: var(--font-mono);
				font-size: 0.84rem;
				color: var(--color-text-faint);
				font-weight: 500;
				padding-top: 0.3rem;
			}
			.entry h3 {
				font-size: 1.08rem;
				font-weight: 600;
				margin: 0 0 0.3rem;
				line-height: 1.3;
				color: var(--color-text-main);
				letter-spacing: -0.012em;
			}
			.entry-venue {
				font-size: 0.92rem;
				color: var(--color-text-muted);
				margin-bottom: 0.5rem;
			}
			.entry-desc {
				margin: 0.4rem 0 0;
				font-size: 0.96rem;
				line-height: 1.6;
				color: var(--color-text-muted);
				max-width: 65ch;
			}
			.entry-desc a {
				color: var(--color-text-main);
				border-bottom: 1px solid var(--color-border);
			}
			.entry-desc a:hover {
				color: var(--color-accent);
				border-bottom-color: var(--color-accent);
			}

			@media (max-width: 720px) {
				.entry {
					grid-template-columns: 1fr;
					gap: 0.4rem;
				}
			}
		</style>
	</body>
</html>
