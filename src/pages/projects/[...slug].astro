---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE } from '../../consts';
import { url } from '../../utils/paths';

export async function getStaticPaths() {
	const projects = await getCollection('projects');
	return projects.map((project) => ({
		params: { slug: project.id },
		props: project,
	}));
}
type Props = CollectionEntry<'projects'>;

const project = Astro.props;
const { Content } = await render(project);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`${project.data.title} | ${SITE_TITLE}`}
			description={project.data.description}
		/>
	</head>
	<body>
		<Header />
		<main>
			<a class="back" href={url('/projects')}>
				<span aria-hidden="true">←</span> All projects
			</a>

			<article class="article">
				<header class="article-head" data-reveal>
					<div class="meta-line">
						<span>{project.data.year}</span>
						{project.data.status && (
							<>
								<span class="dot">·</span>
								<span>{project.data.status}</span>
							</>
						)}
						{project.data.organization && (
							<>
								<span class="dot">·</span>
								<span>{project.data.organization}</span>
							</>
						)}
					</div>

					<h1>{project.data.title}</h1>

					{project.data.role && (
						<div class="byline">{project.data.role}</div>
					)}

					<p class="lede">{project.data.description}</p>

					{project.data.tags && project.data.tags.length > 0 && (
						<div class="tag-row">
							{project.data.tags.map((tag) => <span class="tag">{tag}</span>)}
						</div>
					)}
				</header>

				<div class="article-body" data-reveal style="--reveal-delay: 100ms;">
					<Content />
				</div>

				{project.data.externalLinks && project.data.externalLinks.length > 0 && (
					<aside class="resources">
						<h2 class="resources-head">Resources</h2>
						<ul class="resources-list">
							{project.data.externalLinks.map((link) => (
								<li>
									<a href={link.href} target="_blank" rel="noopener noreferrer">
										{link.label} <span class="ext" aria-hidden="true">↗</span>
									</a>
								</li>
							))}
						</ul>
					</aside>
				)}

				<div class="article-foot">
					<a href={url('/projects')}>← All projects</a>
				</div>
			</article>
		</main>
		<Footer />

		<style>
			.back {
				display: inline-block;
				font-size: 0.88rem;
				color: var(--color-text-muted);
				border: none;
				margin: 1rem 0 2rem;
			}
			.back:hover { color: var(--color-accent); border: none; }
			.back span { color: var(--color-accent); margin-right: 0.4rem; }

			.article-head {
				padding-bottom: 2.5rem;
				border-bottom: 1px solid var(--color-border);
				margin-bottom: 2.5rem;
				max-width: 65ch;
			}
			.meta-line {
				display: flex;
				flex-wrap: wrap;
				gap: 0.6rem;
				font-family: var(--font-mono);
				font-size: 0.82rem;
				color: var(--color-text-faint);
				margin-bottom: 1.25rem;
				font-weight: 500;
			}
			.meta-line .dot { color: var(--color-text-faint); }
			h1 {
				margin: 0 0 1rem;
			}
			.byline {
				font-size: 1rem;
				color: var(--color-text-muted);
				margin-bottom: 1.25rem;
				font-weight: 500;
			}
			.lede {
				font-size: 1.18rem;
				line-height: 1.6;
				color: var(--color-text-muted);
				margin: 0 0 1rem;
			}
			.tag-row {
				display: flex;
				gap: 0.4rem;
				flex-wrap: wrap;
				margin-top: 1.25rem;
			}
			.tag {
				font-family: var(--font-mono);
				font-size: 0.7rem;
				color: var(--color-text-faint);
				padding: 0.2rem 0.55rem;
				border: 1px solid var(--color-border);
				border-radius: var(--radius-sm);
				font-weight: 500;
			}

			.article-body {
				max-width: 65ch;
				font-size: 1.04rem;
				line-height: 1.7;
				color: var(--color-text-main);
			}
			.article-body :global(h2) {
				font-size: 1.4rem;
				margin: 2.5rem 0 0.85rem;
				font-weight: 600;
				letter-spacing: -0.012em;
			}
			.article-body :global(h3) {
				font-size: 1.12rem;
				margin: 2rem 0 0.65rem;
				font-weight: 600;
			}
			.article-body :global(p) {
				margin-bottom: 1.1rem;
				color: var(--color-text-main);
			}
			.article-body :global(a) {
				color: var(--color-text-main);
				border-bottom: 1px solid var(--color-border);
			}
			.article-body :global(a:hover) {
				color: var(--color-accent);
				border-bottom-color: var(--color-accent);
			}
			.article-body :global(ul), .article-body :global(ol) {
				margin: 0.75rem 0 1.5rem;
				padding-left: 1.5rem;
			}
			.article-body :global(li) {
				margin-bottom: 0.4rem;
				color: var(--color-text-main);
			}

			.resources {
				margin-top: 4rem;
				max-width: 65ch;
				padding: 1.75rem;
				background: var(--color-bg-subtle);
				border: 1px solid var(--color-border);
				border-radius: var(--radius);
			}
			.resources-head {
				font-size: 0.8rem;
				font-family: var(--font-mono);
				font-weight: 500;
				color: var(--color-text-faint);
				margin: 0 0 1rem;
				letter-spacing: 0.04em;
			}
			.resources-list {
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.resources-list li {
				margin-bottom: 0.5rem;
				font-size: 0.95rem;
				line-height: 1.5;
			}
			.resources-list a {
				color: var(--color-text-main);
				border-bottom: 1px solid var(--color-border);
			}
			.resources-list a:hover {
				color: var(--color-accent);
				border-bottom-color: var(--color-accent);
			}
			.resources-list .ext { color: var(--color-text-faint); }

			.article-foot {
				margin-top: 4rem;
				padding-top: 1.5rem;
				border-top: 1px solid var(--color-border);
			}
			.article-foot a {
				font-size: 0.88rem;
				color: var(--color-text-muted);
				border: none;
			}
			.article-foot a:hover { color: var(--color-accent); border: none; }
		</style>
	</body>
</html>
