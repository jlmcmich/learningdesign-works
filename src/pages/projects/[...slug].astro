---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_TITLE } from '../../consts';
import { url } from '../../utils/paths';

export async function getStaticPaths() {
	const projects = await getCollection('projects');
	return projects.map((project) => ({
		params: { slug: project.id },
		props: project,
	}));
}
type Props = CollectionEntry<'projects'>;

const project = Astro.props;
const { Content } = await render(project);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${project.data.title} | ${SITE_TITLE}`} description={project.data.description} />
		<style>
			.project-header {
				padding: 3rem 0 2rem 0;
				border-bottom: 1px solid var(--color-border);
				margin-bottom: 2.5rem;
			}
			.project-header .meta {
				font-family: var(--font-sans);
				font-size: 0.85rem;
				text-transform: uppercase;
				letter-spacing: 0.08em;
				color: var(--color-text-muted);
				margin-bottom: 0.75rem;
			}
			.project-header h1 {
				font-family: var(--font-serif);
				font-size: 2.5rem;
				line-height: 1.15;
				margin: 0 0 1rem 0;
			}
			.project-header .lede {
				font-size: 1.1rem;
				color: var(--color-text-muted);
				max-width: 720px;
				line-height: 1.65;
			}
			.project-body {
				max-width: 720px;
				line-height: 1.75;
			}
			.project-body h2 {
				font-family: var(--font-serif);
				margin-top: 2.5rem;
			}
			.project-body a {
				color: var(--color-accent);
			}
			.external-links {
				margin-top: 3rem;
				padding-top: 2rem;
				border-top: 1px solid var(--color-border);
			}
			.external-links h3 {
				font-family: var(--font-serif);
				margin-bottom: 1rem;
			}
			.external-links ul {
				list-style: none;
				padding: 0;
			}
			.external-links li {
				margin-bottom: 0.5rem;
			}
			.back-link {
				display: inline-block;
				margin-bottom: 1rem;
				font-size: 0.9rem;
				color: var(--color-text-muted);
				text-decoration: none;
			}
			.back-link:hover { color: var(--color-accent); }
		</style>
	</head>
	<body>
		<Header />
		<main>
			<a class="back-link" href={url('/projects')}>&larr; All Projects</a>
			<section class="project-header">
				<div class="meta">
					{project.data.year}
					{project.data.role && ` · ${project.data.role}`}
					{project.data.organization && ` · ${project.data.organization}`}
				</div>
				<h1>{project.data.title}</h1>
				<p class="lede">{project.data.description}</p>
			</section>

			<article class="project-body">
				<Content />

				{project.data.externalLinks && project.data.externalLinks.length > 0 && (
					<div class="external-links">
						<h3>Resources</h3>
						<ul>
							{project.data.externalLinks.map((link) => (
								<li>
									<a href={link.href} target="_blank" rel="noopener noreferrer">{link.label}</a>
								</li>
							))}
						</ul>
					</div>
				)}
			</article>
		</main>
		<Footer />
	</body>
</html>
