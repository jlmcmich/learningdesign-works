---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';
import { url } from '../utils/paths';

const projects = (await getCollection('projects')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Projects | ${SITE_TITLE}`}
			description="Selected work spanning instructional design, information literacy, mentorship, and AI in higher education."
		/>
	</head>
	<body>
		<Header />
		<main>
			<section class="page-head" data-reveal>
				<h1>Projects</h1>
				<p class="page-lede">
					Selected work spanning a decade in higher education — instructional design, information literacy, mentorship programs, and the integration of artificial intelligence into teaching and learning.
				</p>
			</section>

			<ul class="entry-list">
				{projects.map((p) => (
					<li class="entry">
						<a class="entry-link" href={url(`/projects/${p.id}/`)}>
							<div class="entry-year">{p.data.year}</div>
							<div class="entry-body">
								<h2 class="entry-title">{p.data.title}</h2>
								{(p.data.role || p.data.organization) && (
									<div class="entry-meta">
										{p.data.role}{p.data.role && p.data.organization ? ' · ' : ''}{p.data.organization}
									</div>
								)}
								<p class="entry-desc">{p.data.description}</p>
								{p.data.tags && p.data.tags.length > 0 && (
									<div class="entry-tags">
										{p.data.tags.map((tag) => <span class="tag">{tag}</span>)}
									</div>
								)}
							</div>
							<div class="entry-arrow" aria-hidden="true">→</div>
						</a>
					</li>
				))}
			</ul>
		</main>
		<Footer />

		<style>
			.page-head {
				padding: 2.5rem 0 3rem;
				border-bottom: 1px solid var(--color-border);
				margin-bottom: 2rem;
			}
			.page-head h1 {
				margin: 0 0 1rem;
			}
			.page-lede {
				font-size: 1.1rem;
				line-height: 1.65;
				color: var(--color-text-muted);
				max-width: 65ch;
				margin: 0 0 1.5rem;
			}
			.page-meta {
				font-family: var(--font-mono);
				font-size: 0.78rem;
				color: var(--color-text-faint);
				font-weight: 500;
			}

			.entry-list {
				list-style: none;
				padding: 0;
				margin: 0;
			}
			.entry { border-bottom: 1px solid var(--color-border); }
			.entry-link {
				display: grid;
				grid-template-columns: 90px 1fr auto;
				gap: 2.5rem;
				padding: 1.75rem 0;
				color: inherit;
				border: none;
				transition: padding 0.2s var(--ease);
			}
			.entry-link:hover {
				padding-left: 0.75rem;
				border: none;
			}
			.entry-link:hover .entry-title { color: var(--color-accent); }
			.entry-link:hover .entry-arrow {
				color: var(--color-accent);
				transform: translateX(4px);
			}
			.entry-year {
				font-family: var(--font-mono);
				font-size: 0.9rem;
				color: var(--color-text-faint);
				font-weight: 500;
				padding-top: 0.3rem;
			}
			.entry-title {
				font-size: 1.4rem;
				font-weight: 600;
				margin: 0 0 0.35rem;
				line-height: 1.25;
				color: var(--color-text-main);
				letter-spacing: -0.015em;
				transition: color 0.15s var(--ease);
			}
			.entry-meta {
				font-size: 0.88rem;
				color: var(--color-text-faint);
				margin-bottom: 0.65rem;
			}
			.entry-desc {
				margin: 0 0 0.85rem;
				font-size: 0.98rem;
				line-height: 1.55;
				color: var(--color-text-muted);
				max-width: 62ch;
			}
			.entry-tags {
				display: flex;
				gap: 0.4rem;
				flex-wrap: wrap;
			}
			.tag {
				font-family: var(--font-mono);
				font-size: 0.7rem;
				color: var(--color-text-faint);
				padding: 0.2rem 0.55rem;
				border: 1px solid var(--color-border);
				border-radius: var(--radius-sm);
				font-weight: 500;
			}
			.entry-arrow {
				font-size: 1.1rem;
				color: var(--color-text-faint);
				padding-top: 0.4rem;
				transition: transform 0.2s var(--ease), color 0.15s var(--ease);
			}

			@media (max-width: 720px) {
				.entry-link {
					grid-template-columns: 60px 1fr;
					gap: 1.25rem;
				}
				.entry-arrow { display: none; }
			}
		</style>
	</body>
</html>
