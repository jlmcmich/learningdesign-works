---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';

const talks = [
	{ year: 'Oct 2026', kind: 'Pre-Conference Workshop', title: 'Designing Learning Environments in an Agentic World: Coordinating Students, Instructors, and AI', venue: 'AAC&U Conference on AI and Higher Education, Atlanta', highlight: false, award: null, link: 'https://www.aacu.org/event/conference-on-ai-and-higher-education' },
	{ year: 'Mar 2026', kind: 'Workshop', title: 'Navigating Intellectual Property, Academic Integrity, and Ethics in AI-Enhanced Education', venue: 'Future of Learning Community', highlight: false, award: null, link: 'https://folcfest.asu.edu/folcfest-workshops-2026', slides: 'https://drive.google.com/drive/folders/1NKa0fArx4pwyf4vVi47Eor0dFqtRB6GP?usp=drive_link' },
	{ year: 'Jan 2026', kind: 'Keynote', title: 'Agentic AI: Challenges and Opportunities for Higher Education', venue: 'AAC&U Institute on AI, Pedagogy, and the Curriculum', highlight: false, award: null },
	{ year: 'Sep 2025', kind: 'Presentation', title: 'AI as a Learning Intervention', venue: 'AAC&U Institute on AI, Pedagogy, and the Curriculum', highlight: false, award: null, slides: 'https://docs.google.com/presentation/d/1Tjpn6aZgR8H4HBIZTgCs_j8zldvMvG1Git_7_rSXJyk/edit?usp=sharing' },
	{ year: 'Sep 2025', kind: 'Presentation', title: 'Using Situated Learning Theory and ChatGPT to Build Scenario-Based Learning Assessments', venue: 'AAC&U Institute on AI, Pedagogy, and the Curriculum', highlight: false, award: null, slides: 'https://docs.google.com/presentation/d/1EBAfwkh8CKUOlqjBBaFxg7XxYhJ17G_TStSJ9dkn1rE/edit?usp=sharing' },
	{ year: 'Feb 2025', kind: 'Webinar', title: 'Make Your Own Instructional Design Tool', venue: 'Online Learning Consortium Webinar Series', highlight: false, award: null, slides: 'https://drive.google.com/drive/folders/1FrUO3xMf_P71ZHJB0ol6_eS4NegZJ3EM?usp=drive_link' },
	{ year: 'Nov 2024', kind: 'Presentation', title: 'AI Design Challenge: Make Your Own Instructional Design Tool!', venue: 'OLC Accelerate · with Sue Huffman', highlight: true, award: 'Innovative Learning Environments & Technologies — Best-in-Track Award', slides: 'https://drive.google.com/drive/folders/1FrUO3xMf_P71ZHJB0ol6_eS4NegZJ3EM?usp=drive_link' },
	{ year: 'Aug 2024', kind: 'Presentation', title: 'AI Innovation Showcase: Enhancing Course Design with GPTs', venue: 'ASU Learning Design Community Summer Camp', highlight: false, award: null },
	{ year: 'Mar 2024', kind: 'Lightning Talk', title: 'Enhancing Course Design with GPTs', venue: 'Future of Learning Community', highlight: false, award: null },
];

const moderatorPanels = [
	{ title: 'AI in Education: Implementing Generative AI in Your Courses', venue: 'IEEE Education', date: 'Jul 2024', link: 'https://www.youtube.com/watch?v=fSEXFLSl8CM' },
	{ title: 'Generative AI Engineering Faculty Panel', venue: 'AI @ ASU Community of Practice', date: 'Feb 2024' },
];
const panelistPanels = [
	{ title: 'The AI Technology Landscape and What Is to Come', venue: 'AAC&U Institute on AI, Pedagogy, and the Curriculum', date: 'Apr 2026' },
	{ title: 'Generative AI: Responsible Use Through Critical Thinking and Digital Literacy', venue: 'Future of Learning Community', date: 'Mar 2024' },
	{ title: 'ChatGPT and Its Implications for the Field of Librarianship', venue: 'ALA Annual Conference, Chicago', date: 'Jun 2023', link: 'https://americanlibrariesmagazine.org/blogs/the-scoop/information-literacy-chatgpt/' },
	{ title: 'Generative AI & ChatGPT Follow-Up Panel', venue: 'SMU Center for Teaching Excellence', date: 'Apr 2023', link: 'https://youtu.be/hkpfYW1Ytj0?si=LVOndRqRlks3BsLD' },
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Talks & Writing | ${SITE_TITLE}`}
			description="Keynotes, presentations, panels, and writing on AI in education."
		/>
	</head>
	<body>
		<Header />
		<main>
			<section class="page-head" data-reveal>
				<h1>Talks &amp; Writing</h1>
				<p class="page-lede">
					Keynotes, conference presentations, panels, and writing on
					generative AI in higher education — from agentic AI and learning interventions
					to information literacy and the changing role of the academic library.
				</p>
			</section>

			<section class="callout" data-reveal style="--reveal-delay: 80ms;">
				<div class="callout-label">Leadership in AI Pedagogy</div>
				<h2>Faculty Mentor — <a href="https://www.aacu.org/event/2025-26-institute-ai-pedagogy-curriculum">AAC&amp;U Institute on AI, Pedagogy, and Curriculum</a></h2>
				<p>
					I serve as Faculty Mentor for the AAC&amp;U Institute on AI, Pedagogy, and Curriculum,
					where I moderated a panel on agentic AI at the most recent convening and mentor university
					groups on their AI implementation strategies.
				</p>
			</section>

			<section class="section">
				<header class="section-head">
					<h2>Keynotes &amp; Presentations</h2>
				</header>

				<ul class="entry-list">
					{talks.map((t) => (
						<li class={`entry${t.highlight ? ' is-highlight' : ''}`}>
							<div class="entry-year">{t.year}</div>
							<div class="entry-body">
								<div class="entry-kind">{t.kind}{t.highlight ? ' · Award' : ''}</div>
								<h3>{t.title}</h3>
								<div class="entry-venue">{t.venue}</div>
								{t.award && <div class="award">{t.award}</div>}
								{t.slides && <a href={t.slides} class="slides-link">Slides →</a>}
								{t.link && <a href={t.link} class="slides-link">Details →</a>}
							</div>
						</li>
					))}
				</ul>
			</section>

			<section class="section">
				<header class="section-head">
					<h2>Panels</h2>
				</header>

				<div class="panels-grid">
					<div>
						<div class="panel-label">As Moderator</div>
						<ul class="panel-list">
							{moderatorPanels.map((p) => (
								<li>
									<div class="panel-title">{p.title}</div>
									<div class="panel-meta">{p.venue} · {p.date}{p.link && <> · <a href={p.link} class="panel-link">Watch →</a></>}</div>
								</li>
							))}
						</ul>
					</div>
					<div>
						<div class="panel-label">As Panelist</div>
						<ul class="panel-list">
							{panelistPanels.map((p) => (
								<li>
									<div class="panel-title">{p.title}</div>
									<div class="panel-meta">{p.venue} · {p.date}{p.link && <> · <a href={p.link} class="panel-link">{p.link.includes('youtu') ? 'Watch' : 'Read'} →</a></>}</div>
								</li>
							))}
						</ul>
					</div>
				</div>
			</section>

			<section class="section">
				<header class="section-head">
					<h2>Writing</h2>
				</header>

				<ol class="bib-list">
					<li>
						<span class="bib-num">1</span>
						<div>
							<a href="https://journal.ilta.ie/index.php/telji/article/view/122/176" target="_blank" rel="noopener noreferrer">
								McMichael, J., Peña, K., &amp; Dalal, M.
								<em>"Technology-Enhanced Student Success Program Short Report: GenAI's Approach for First-Year, First-Generation College Students."</em>
							</a>
							<span class="bib-venue">Irish Journal of Technology Enhanced Learning</span>, Vol. 7 No. 2, July 2023.
						</div>
					</li>
					<li>
						<span class="bib-num">2</span>
						<div>
							<a href="https://blog.smu.edu/smulibraries/2023/01/20/artificial-intelligence-and-the-research-paper-a-librarians-perspective/" target="_blank" rel="noopener noreferrer">
								<em>"Artificial Intelligence and the Research Paper: A Librarian's Perspective."</em>
							</a>
							<span class="bib-venue">SMU Libraries Blog</span>, January 2023.
						</div>
					</li>
				</ol>
			</section>
		</main>
		<Footer />

		<style>
			.page-head {
				padding: 2.5rem 0 3rem;
				border-bottom: 1px solid var(--color-border);
				margin-bottom: 2.5rem;
			}
			.page-head h1 { margin: 0 0 1rem; }
			.page-lede {
				font-size: 1.1rem;
				line-height: 1.65;
				color: var(--color-text-muted);
				max-width: 65ch;
				margin: 0;
			}

			.callout {
				padding: 1.5rem 1.75rem;
				background: var(--color-bg-subtle);
				border: 1px solid var(--color-border);
				border-left: 3px solid var(--color-accent);
				border-radius: var(--radius);
				margin-bottom: 4rem;
				max-width: 70ch;
			}
			.callout-label {
				font-family: var(--font-mono);
				font-size: 0.74rem;
				color: var(--color-text-faint);
				font-weight: 500;
				margin-bottom: 0.6rem;
			}
			.callout h2 {
				font-size: 1.15rem;
				font-weight: 600;
				margin: 0 0 0.65rem;
				letter-spacing: -0.012em;
			}
			.callout p {
				margin: 0;
				font-size: 0.95rem;
				line-height: 1.6;
				color: var(--color-text-muted);
			}

			.section { margin-bottom: 4rem; }
			.section-head {
				display: flex;
				justify-content: space-between;
				align-items: baseline;
				gap: 1rem;
				margin-bottom: 1.5rem;
				padding-bottom: 0.75rem;
				border-bottom: 1px solid var(--color-border);
			}
			.section-head h2 {
				margin: 0;
				font-size: 1.45rem;
				font-weight: 600;
				letter-spacing: -0.018em;
			}
			.section-count {
				font-family: var(--font-mono);
				font-size: 0.78rem;
				color: var(--color-text-faint);
				font-weight: 500;
			}

			.entry-list {
				list-style: none;
				padding: 0;
				margin: 0;
			}
			.entry {
				display: grid;
				grid-template-columns: 110px 1fr;
				gap: 2rem;
				padding: 1.25rem 0;
				border-bottom: 1px solid var(--color-border-soft);
			}
			.entry:last-child { border-bottom: none; }
			.entry.is-highlight {
				margin: 0.4rem 0;
				padding: 1.4rem 1.25rem;
				background: var(--color-bg-subtle);
				border: 1px solid var(--color-border);
				border-radius: var(--radius);
			}
			.entry-year {
				font-family: var(--font-mono);
				font-size: 0.84rem;
				color: var(--color-text-faint);
				font-weight: 500;
				padding-top: 0.3rem;
			}
			.entry-kind {
				font-family: var(--font-mono);
				font-size: 0.72rem;
				color: var(--color-text-faint);
				font-weight: 500;
				margin-bottom: 0.4rem;
			}
			.entry h3 {
				font-size: 1.08rem;
				font-weight: 600;
				margin: 0 0 0.3rem;
				line-height: 1.3;
				color: var(--color-text-main);
				letter-spacing: -0.012em;
			}
			.entry-venue {
				font-size: 0.92rem;
				color: var(--color-text-muted);
			}
			.award {
				display: inline-block;
				margin-top: 0.6rem;
				padding: 0.25rem 0.65rem;
				background: var(--color-bg);
				border: 1px solid var(--color-accent);
				color: var(--color-accent);
				font-family: var(--font-mono);
				font-size: 0.7rem;
				border-radius: var(--radius-sm);
				font-weight: 500;
			}
			.slides-link {
				display: inline-block;
				margin-top: 0.5rem;
				font-family: var(--font-mono);
				font-size: 0.75rem;
				font-weight: 500;
				color: var(--color-text-muted);
			}
			.slides-link:hover { color: var(--color-accent); }

			.panels-grid {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 3rem;
			}
			.panel-label {
				font-family: var(--font-mono);
				font-size: 0.74rem;
				color: var(--color-text-faint);
				font-weight: 500;
				margin-bottom: 1rem;
				padding-bottom: 0.5rem;
				border-bottom: 1px solid var(--color-border);
			}
			.panel-list {
				list-style: none;
				padding: 0;
				margin: 0;
			}
			.panel-list li {
				padding: 0.85rem 0;
				border-bottom: 1px solid var(--color-border-soft);
			}
			.panel-list li:last-child { border-bottom: none; }
			.panel-title {
				font-size: 1rem;
				font-weight: 500;
				color: var(--color-text-main);
				margin-bottom: 0.3rem;
				line-height: 1.35;
			}
			.panel-meta {
				font-family: var(--font-mono);
				font-size: 0.74rem;
				color: var(--color-text-faint);
				font-weight: 500;
			}
			.panel-link {
				color: var(--color-text-muted);
				font-weight: 500;
			}
			.panel-link:hover { color: var(--color-accent); }

			.bib-list {
				list-style: none;
				padding: 0;
				margin: 0;
				counter-reset: none;
			}
			.bib-list > li {
				display: grid;
				grid-template-columns: 36px 1fr;
				gap: 1rem;
				padding: 1rem 0;
				border-bottom: 1px solid var(--color-border-soft);
				font-size: 0.98rem;
				line-height: 1.65;
				color: var(--color-text-main);
			}
			.bib-list > li:last-child { border-bottom: none; }
			.bib-num {
				font-family: var(--font-mono);
				font-size: 0.85rem;
				color: var(--color-text-faint);
				font-weight: 500;
				padding-top: 0.1rem;
			}
			.bib-list em {
				color: var(--color-text-main);
				font-style: italic;
			}
			.bib-list .bib-venue {
				color: var(--color-text-muted);
				font-style: italic;
			}
			.bib-list a {
				color: var(--color-text-main);
				border-bottom: 1px solid var(--color-border);
			}
			.bib-list a:hover {
				color: var(--color-accent);
				border-bottom-color: var(--color-accent);
			}

			@media (max-width: 720px) {
				.entry {
					grid-template-columns: 1fr;
					gap: 0.4rem;
				}
				.panels-grid {
					grid-template-columns: 1fr;
					gap: 2rem;
				}
			}
		</style>
	</body>
</html>
