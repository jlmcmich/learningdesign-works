---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE } from '../../consts';
import { getCollection } from 'astro:content';
import { url } from '../../utils/paths';

const prompts = (await getCollection('prompts')).sort((a, b) => {
	const orderA = a.data.order ?? 999;
	const orderB = b.data.order ?? 999;
	if (orderA !== orderB) return orderA - orderB;
	return a.data.title.localeCompare(b.data.title);
});

const grouped = prompts.reduce((acc, p) => {
	const suite = p.data.suite ?? 'Other Prompts';
	(acc[suite] ||= []).push(p);
	return acc;
}, {} as Record<string, typeof prompts>);

const suiteOrder = ["ASU's Learning Design Suite", 'Learning Design Tools', 'Classroom Learning Tools', 'Other Prompts'];
const orderedSuites = [
	...suiteOrder.filter((s) => grouped[s]),
	...Object.keys(grouped).filter((s) => !suiteOrder.includes(s)),
];

const fmtDate = (d: Date) => d.toLocaleDateString('en-us', { month: 'short', year: 'numeric' });
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`AI for Learning Prompts | ${SITE_TITLE}`}
			description="A working library of prompts I've used in course-design and faculty-development work, including the complete custom-instruction sets from ASU's Learning Design Suite."
		/>
	</head>
	<body>
		<Header />
		<main>
			<section class="page-head" data-reveal>
				<h1>AI for Learning Prompts</h1>
				<p class="page-lede">
					A working library of prompts I've used in course-design and faculty-development work.
					Each one started with a real problem an instructor or designer was trying to solve,
					and got refined through use.
				</p>
				<p class="page-lede">
					Each entry below includes the <strong>complete system prompt or custom instructions</strong>.
					Many were originally deployed as custom GPTs on ChatGPT and have since been adapted to other
					platforms, including <a href="https://ai.asu.edu/technical-foundation/createai-builder">ASU's CreateAI Builder</a>.
				</p>
				<div class="page-note">
					Some prompts reference supporting documents that lived in the original GPT's knowledge base.
					Without those materials, behavior may vary from the intended use.
				</div>
			</section>

			{orderedSuites.map((suite) => (
				<section class="suite">
					<header class="suite-head">
						<h2>{suite}</h2>
					</header>

					<ul class="prompt-list">
						{grouped[suite].map((prompt) => (
							<li>
								<a class="prompt-card" href={url(`/ai-prompts/${prompt.id}/`)}>
									<div class="card-head">
										<h3>{prompt.data.title}</h3>
										<span class="card-arrow" aria-hidden="true">→</span>
									</div>
									<p>{prompt.data.description}</p>
									<div class="card-foot">
										<span class="updated">Updated {fmtDate(prompt.data.lastUpdated)}</span>
										{prompt.data.tags && prompt.data.tags.length > 0 && (
											<span class="tag-row">
												{prompt.data.tags.slice(0, 2).map((t) => <span class="tag">{t}</span>)}
											</span>
										)}
									</div>
								</a>
							</li>
						))}
					</ul>
				</section>
			))}
		</main>
		<Footer />

		<style>
			.page-head {
				padding: 2.5rem 0 3rem;
				border-bottom: 1px solid var(--color-border);
				margin-bottom: 3rem;
				max-width: 70ch;
			}
			.page-head h1 { margin: 0 0 1rem; }
			.page-lede {
				font-size: 1.1rem;
				line-height: 1.65;
				color: var(--color-text-muted);
				margin: 0 0 1.25rem;
			}
			.page-lede strong { color: var(--color-text-main); font-weight: 600; }
			.page-note {
				padding: 0.85rem 1rem;
				background: var(--color-bg-subtle);
				border-left: 2px solid var(--color-accent);
				border-radius: var(--radius-sm);
				font-size: 0.92rem;
				color: var(--color-text-muted);
				line-height: 1.55;
			}

			.suite { margin-bottom: 4rem; }
			.suite-head {
				display: flex;
				justify-content: space-between;
				align-items: baseline;
				gap: 1rem;
				margin-bottom: 1.5rem;
				padding-bottom: 0.75rem;
				border-bottom: 1px solid var(--color-border);
			}
			.suite-head h2 {
				margin: 0;
				font-size: 1.45rem;
				font-weight: 600;
				letter-spacing: -0.018em;
			}
			.suite-count {
				font-family: var(--font-mono);
				font-size: 0.78rem;
				color: var(--color-text-faint);
				font-weight: 500;
			}

			.prompt-list {
				list-style: none;
				padding: 0;
				margin: 0;
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
				gap: 1rem;
			}
			.prompt-card {
				display: flex;
				flex-direction: column;
				gap: 0.65rem;
				padding: 1.25rem 1.35rem;
				background: var(--color-bg);
				border: 1px solid var(--color-border);
				border-radius: var(--radius);
				color: inherit;
				height: 100%;
				transition: border-color 0.15s var(--ease), background 0.15s var(--ease), transform 0.15s var(--ease);
			}
			.prompt-card:hover {
				border-color: var(--color-text-main);
				background: var(--color-bg-subtle);
				border-bottom-color: var(--color-text-main);
			}
			.prompt-card:hover .card-arrow { transform: translateX(3px); color: var(--color-accent); }
			.prompt-card:hover h3 { color: var(--color-accent); }
			.card-head {
				display: flex;
				justify-content: space-between;
				gap: 0.85rem;
				align-items: flex-start;
			}
			.prompt-card h3 {
				font-size: 1.04rem;
				font-weight: 600;
				margin: 0;
				color: var(--color-text-main);
				line-height: 1.3;
				letter-spacing: -0.01em;
				transition: color 0.15s var(--ease);
			}
			.card-arrow {
				color: var(--color-text-faint);
				font-size: 0.95rem;
				transition: transform 0.15s var(--ease), color 0.15s var(--ease);
				flex-shrink: 0;
			}
			.prompt-card p {
				margin: 0;
				font-size: 0.9rem;
				line-height: 1.55;
				color: var(--color-text-muted);
				flex: 1;
			}
			.card-foot {
				display: flex;
				justify-content: space-between;
				gap: 0.75rem;
				align-items: center;
				font-family: var(--font-mono);
				font-size: 0.7rem;
				color: var(--color-text-faint);
				font-weight: 500;
				padding-top: 0.5rem;
				border-top: 1px solid var(--color-border-soft);
			}
			.tag-row {
				display: flex;
				gap: 0.3rem;
				flex-wrap: wrap;
			}
			.tag-row .tag {
				font-family: var(--font-mono);
				font-size: 0.66rem;
				color: var(--color-text-faint);
				padding: 0.15rem 0.45rem;
				border: 1px solid var(--color-border);
				border-radius: 3px;
				font-weight: 500;
			}
		</style>
	</body>
</html>
