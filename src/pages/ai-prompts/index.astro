---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE } from '../../consts';
import { getCollection } from 'astro:content';
import { url } from '../../utils/paths';

const prompts = (await getCollection('prompts')).sort((a, b) => {
	const orderA = a.data.order ?? 999;
	const orderB = b.data.order ?? 999;
	if (orderA !== orderB) return orderA - orderB;
	return a.data.title.localeCompare(b.data.title);
});

const grouped = prompts.reduce((acc, p) => {
	const suite = p.data.suite ?? 'Other Prompts';
	if (!acc[suite]) acc[suite] = [];
	acc[suite].push(p);
	return acc;
}, {} as Record<string, typeof prompts>);

const suiteOrder = ["ASU's Learning Design Suite", 'Other Prompts'];
const orderedSuites = [
	...suiteOrder.filter((s) => grouped[s]),
	...Object.keys(grouped).filter((s) => !suiteOrder.includes(s)),
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`AI Prompts | ${SITE_TITLE}`} description="A repository of AI prompts designed to transform course design workflows and help educators create pedagogically sound learning experiences." />
		<style>
			.prompts-hero {
				padding: 3rem 0 2rem 0;
				border-bottom: 1px solid var(--color-border);
				margin-bottom: 3rem;
			}
			.prompts-hero h1 {
				font-family: var(--font-serif);
				font-size: 3rem;
				margin: 0 0 1rem 0;
				letter-spacing: -0.02em;
			}
			.prompts-hero p {
				font-size: 1.1rem;
				color: var(--color-text-muted);
				max-width: 720px;
				line-height: 1.7;
				margin-bottom: 1rem;
			}
			.note {
				padding: 1rem 1.25rem;
				background: var(--color-bg-offset);
				border-left: 3px solid var(--color-accent);
				border-radius: 6px;
				margin-top: 1.5rem;
				font-size: 0.95rem;
				color: var(--color-text-muted);
			}
			.suite-section {
				margin-bottom: 3.5rem;
			}
			.suite-section h2 {
				font-family: var(--font-serif);
				font-size: 1.75rem;
				margin: 0 0 1.5rem 0;
				padding-bottom: 0.5rem;
				border-bottom: 1px solid var(--color-border);
			}
			.prompt-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
				gap: 1.5rem;
			}
			.prompt-card {
				display: block;
				padding: 1.5rem;
				border: 1px solid var(--color-border);
				border-radius: 12px;
				background: var(--color-bg-offset);
				text-decoration: none;
				color: inherit;
				transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s;
			}
			.prompt-card:hover {
				transform: translateY(-4px);
				border-color: var(--color-accent);
				box-shadow: var(--shadow-md);
			}
			.prompt-card h3 {
				font-family: var(--font-serif);
				font-size: 1.2rem;
				margin: 0 0 0.5rem 0;
				color: var(--color-text-main);
			}
			.prompt-card p {
				margin: 0;
				color: var(--color-text-muted);
				font-size: 0.9rem;
				line-height: 1.55;
			}
			.prompt-card .updated {
				display: block;
				margin-top: 0.75rem;
				font-size: 0.75rem;
				color: var(--color-text-muted);
				text-transform: uppercase;
				letter-spacing: 0.05em;
			}
			@media (max-width: 720px) {
				.prompts-hero h1 { font-size: 2.25rem; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="prompts-hero">
				<h1>AI Prompts</h1>
				<p>
					A collection of AI prompts designed to transform course design workflows and help educators
					create pedagogically sound learning experiences. Originally developed as ChatGPT custom GPTs,
					these prompts work effectively across most popular large language models.
				</p>
				<p>
					Each tool includes its title, description, and complete prompt/custom instructions. The most
					recent additions &mdash; ASU's Learning Design Suite &mdash; include comprehensive documentation
					for broader educational audiences.
				</p>
				<div class="note">
					<strong>Note:</strong> Some prompts reference supporting documents in knowledge bases. Without
					these materials, their behavior may vary from intended use.
				</div>
				<div class="note" style="border-left-color: var(--color-text-muted);">
					<strong>Statement of Acknowledgement:</strong> These tools rest on the invaluable intellectual
					contributions of countless researchers, writers, creators, and thinkers &mdash; both known and
					unknown &mdash; whose work forms the foundation of large language models.
				</div>
			</section>

			{orderedSuites.map((suite) => (
				<section class="suite-section">
					<h2>{suite}</h2>
					<div class="prompt-grid">
						{grouped[suite].map((prompt) => (
							<a class="prompt-card" href={url(`/ai-prompts/${prompt.id}/`)}>
								<h3>{prompt.data.title}</h3>
								<p>{prompt.data.description}</p>
								<span class="updated">
									Updated {prompt.data.lastUpdated.toLocaleDateString('en-us', { year: 'numeric', month: 'short' })}
								</span>
							</a>
						))}
					</div>
				</section>
			))}
		</main>
		<Footer />
	</body>
</html>
