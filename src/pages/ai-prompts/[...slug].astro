---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE } from '../../consts';
import { url } from '../../utils/paths';

export async function getStaticPaths() {
	const prompts = await getCollection('prompts');
	return prompts.map((prompt) => ({
		params: { slug: prompt.id },
		props: prompt,
	}));
}
type Props = CollectionEntry<'prompts'>;

const prompt = Astro.props;
const { Content } = await render(prompt);
const updatedLong = prompt.data.lastUpdated.toLocaleDateString('en-us', {
	month: 'long',
	year: 'numeric',
});
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`${prompt.data.title} | AI Prompts | ${SITE_TITLE}`}
			description={prompt.data.description}
		/>
	</head>
	<body>
		<Header />
		<main>
			<a class="back" href={url('/ai-prompts')}>
				<span aria-hidden="true">←</span> All prompts
			</a>

			<article class="article">
				<header class="article-head" data-reveal>
					<div class="meta-line">
						{prompt.data.suite && <span>{prompt.data.suite}</span>}
						{prompt.data.suite && <span class="dot">·</span>}
						<span>Updated {updatedLong}</span>
					</div>

					<h1>{prompt.data.title}</h1>

					<p class="lede">{prompt.data.description}</p>

					{prompt.data.tags && prompt.data.tags.length > 0 && (
						<div class="tag-row">
							{prompt.data.tags.map((tag) => <span class="tag">{tag}</span>)}
						</div>
					)}
				</header>

				<section class="verbatim" data-reveal style="--reveal-delay: 100ms;">
					<header class="verbatim-head">
						<div class="verbatim-title">
							<h2>Full prompt</h2>
							<span class="char-count" id="char-count">— characters</span>
						</div>
						<button class="copy-btn" id="copy-btn" type="button" data-default="Copy" data-copied="Copied ✓">
							<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
							<span class="btn-label">Copy</span>
						</button>
					</header>

					<div class="verbatim-body" id="verbatim-body">
						<Content />
					</div>
				</section>

				<div class="article-foot">
					<a href={url('/ai-prompts')}>← All prompts</a>
				</div>
			</article>
		</main>
		<Footer />

		<script>
			const btn = document.getElementById('copy-btn') as HTMLButtonElement | null;
			const body = document.getElementById('verbatim-body');
			const counter = document.getElementById('char-count');
			const labelEl = btn?.querySelector('.btn-label') as HTMLElement | null;

			const codeEl = body?.querySelector('pre > code, pre');
			const text = (codeEl?.textContent || body?.textContent || '').trim();

			if (counter) counter.textContent = `${text.length.toLocaleString()} characters`;

			btn?.addEventListener('click', async () => {
				if (!text || !labelEl || !btn) return;
				try {
					await navigator.clipboard.writeText(text);
					labelEl.textContent = btn.dataset.copied || 'Copied';
					btn.classList.add('is-copied');
					setTimeout(() => {
						labelEl.textContent = btn.dataset.default || 'Copy';
						btn.classList.remove('is-copied');
					}, 1800);
				} catch {
					labelEl.textContent = 'Press ⌘C';
				}
			});
		</script>

		<style>
			.back {
				display: inline-block;
				font-size: 0.88rem;
				color: var(--color-text-muted);
				border: none;
				margin: 1rem 0 2rem;
			}
			.back:hover { color: var(--color-accent); border: none; }
			.back span { color: var(--color-accent); margin-right: 0.4rem; }

			.article-head {
				padding-bottom: 2.5rem;
				border-bottom: 1px solid var(--color-border);
				margin-bottom: 2.5rem;
				max-width: 65ch;
			}
			.meta-line {
				display: flex;
				flex-wrap: wrap;
				gap: 0.6rem;
				font-family: var(--font-mono);
				font-size: 0.82rem;
				color: var(--color-text-faint);
				margin-bottom: 1.25rem;
				font-weight: 500;
			}
			.meta-line .dot { color: var(--color-text-faint); }
			h1 { margin: 0 0 1rem; }
			.lede {
				font-size: 1.18rem;
				line-height: 1.6;
				color: var(--color-text-muted);
				margin: 0;
			}
			.tag-row {
				display: flex;
				gap: 0.4rem;
				flex-wrap: wrap;
				margin-top: 1.25rem;
			}
			.tag {
				font-family: var(--font-mono);
				font-size: 0.7rem;
				color: var(--color-text-faint);
				padding: 0.2rem 0.55rem;
				border: 1px solid var(--color-border);
				border-radius: var(--radius-sm);
				font-weight: 500;
			}

			/* === VERBATIM BLOCK === */
			.verbatim {
				margin-top: 1rem;
			}
			.verbatim-head {
				display: flex;
				justify-content: space-between;
				align-items: end;
				gap: 1rem;
				margin-bottom: 1rem;
			}
			.verbatim-title {
				display: flex;
				align-items: baseline;
				gap: 0.85rem;
				flex-wrap: wrap;
			}
			.verbatim-head h2 {
				margin: 0;
				font-size: 1.05rem;
				font-weight: 600;
				letter-spacing: -0.012em;
			}
			.char-count {
				font-family: var(--font-mono);
				font-size: 0.76rem;
				color: var(--color-text-faint);
				font-weight: 500;
			}

			.copy-btn {
				display: inline-flex;
				align-items: center;
				gap: 0.45rem;
				padding: 0.5rem 0.85rem;
				font-family: var(--font-sans);
				font-size: 0.85rem;
				font-weight: 500;
				background: var(--color-bg);
				color: var(--color-text-main);
				border: 1px solid var(--color-border);
				border-radius: var(--radius);
				cursor: pointer;
				transition: background 0.15s var(--ease), color 0.15s var(--ease), border-color 0.15s var(--ease);
			}
			.copy-btn:hover {
				background: var(--color-text-main);
				color: var(--color-bg);
				border-color: var(--color-text-main);
			}
			.copy-btn.is-copied {
				background: var(--color-accent);
				color: #FFFFFF;
				border-color: var(--color-accent);
			}

			/* === Verbatim body — force theme-aware colors, override anything Shiki may still inject === */
			.verbatim-body :global(pre),
			.verbatim-body :global(pre[style]) {
				background: var(--color-bg-code) !important;
				background-color: var(--color-bg-code) !important;
				color: var(--color-text-main) !important;
				border: 1px solid var(--color-border);
				border-radius: var(--radius);
				padding: 1.5rem;
				margin: 0;
				font-family: var(--font-mono);
				font-size: 0.85rem;
				line-height: 1.7;
				overflow-x: auto;
				max-height: 720px;
				overflow-y: auto;
				white-space: pre-wrap;
				word-wrap: break-word;
			}
			.verbatim-body :global(pre code),
			.verbatim-body :global(pre code[style]),
			.verbatim-body :global(pre code span),
			.verbatim-body :global(pre code span[style]) {
				background: transparent !important;
				background-color: transparent !important;
				color: var(--color-text-main) !important;
				font-family: var(--font-mono) !important;
				font-size: inherit !important;
				padding: 0 !important;
				white-space: pre-wrap !important;
				word-wrap: break-word !important;
				display: inline;
			}
			.verbatim-body :global(pre code) {
				display: block;
			}
			.verbatim-body :global(pre)::-webkit-scrollbar { width: 10px; height: 10px; }
			.verbatim-body :global(pre)::-webkit-scrollbar-track { background: transparent; }
			.verbatim-body :global(pre)::-webkit-scrollbar-thumb {
				background: var(--color-border);
				border-radius: 5px;
			}

			/* Any non-code intro paragraph */
			.verbatim-body :global(p) {
				font-family: var(--font-sans);
				font-size: 0.95rem;
				line-height: 1.6;
				color: var(--color-text-muted);
				margin: 0 0 1.25rem;
				max-width: 65ch;
			}

			.article-foot {
				margin-top: 4rem;
				padding-top: 1.5rem;
				border-top: 1px solid var(--color-border);
			}
			.article-foot a {
				font-size: 0.88rem;
				color: var(--color-text-muted);
				border: none;
			}
			.article-foot a:hover { color: var(--color-accent); border: none; }

			@media (max-width: 600px) {
				.verbatim-head {
					flex-direction: column;
					align-items: flex-start;
				}
				.verbatim-body :global(pre) {
					padding: 1rem;
					font-size: 0.78rem;
				}
			}
		</style>
	</body>
</html>
