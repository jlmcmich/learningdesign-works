---
import { CV_URL, SITE_TITLE } from '../consts';
import { url } from '../utils/paths';

const cvHref = CV_URL ? url(CV_URL) : null;
const navItems = [
	{ href: '/', label: 'Home' },
	{ href: '/projects', label: 'Projects' },
	{ href: '/ai-prompts', label: 'AI Prompts' },
	{ href: '/talks', label: 'Talks & Writing' },
];
const currentPath = Astro.url.pathname.replace(/\/+$/, '') || '/';
const basePath = import.meta.env.BASE_URL.replace(/\/+$/, '');
const isActive = (href: string) => {
	const target = `${basePath}${href}`.replace(/\/+$/, '') || '/';
	if (target === '/') return currentPath === basePath || currentPath === '/' || currentPath === '';
	return currentPath === target || currentPath.startsWith(target + '/');
};
---

<header class="masthead">
	<div class="masthead-inner">
		<a class="brand" href={url('/')}>{SITE_TITLE}</a>

		<nav class="nav-desktop" aria-label="Primary">
			{navItems.slice(1).map((item) => (
				<a
					href={url(item.href)}
					class:list={['nav-link', isActive(item.href) && 'is-active']}
				>
					{item.label}
				</a>
			))}
			{cvHref && <a href={cvHref} class="nav-link" target="_blank" rel="noopener noreferrer">CV</a>}
		</nav>

		<div class="masthead-controls">
			<button id="theme-toggle" class="icon-btn" aria-label="Toggle dark mode" type="button">
				<svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"></path></svg>
				<svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
			</button>
			<button id="menu-toggle" class="icon-btn menu-only" aria-label="Toggle menu" type="button">
				<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="7" x2="20" y2="7"></line><line x1="4" y1="13" x2="20" y2="13"></line><line x1="4" y1="19" x2="20" y2="19"></line></svg>
			</button>
		</div>
	</div>

	<div id="mobile-menu" class="mobile-menu" hidden>
		{navItems.map((item) => (
			<a href={url(item.href)} class:list={['mobile-link', isActive(item.href) && 'is-active']}>
				{item.label}
			</a>
		))}
		{cvHref && <a href={cvHref} class="mobile-link" target="_blank" rel="noopener noreferrer">CV</a>}
	</div>
</header>

<script>
	document.getElementById('theme-toggle')?.addEventListener('click', () => {
		const current = document.documentElement.getAttribute('data-theme') === 'dark' ? 'dark' : 'light';
		const next = current === 'dark' ? 'light' : 'dark';
		(window as any).__setPreferredTheme?.(next);
		try { localStorage.setItem('theme', next); } catch {}
	});

	const menuBtn = document.getElementById('menu-toggle');
	const menu = document.getElementById('mobile-menu');
	menuBtn?.addEventListener('click', () => {
		if (!menu) return;
		const isOpen = menu.hasAttribute('open');
		if (isOpen) {
			menu.removeAttribute('open');
			menu.setAttribute('hidden', '');
		} else {
			menu.removeAttribute('hidden');
			menu.setAttribute('open', '');
		}
	});
</script>

<style>
	.masthead {
		position: relative;
		z-index: 10;
		background: var(--color-bg);
		border-bottom: 1px solid var(--color-border);
	}
	.masthead-inner {
		max-width: 1100px;
		margin: 0 auto;
		display: grid;
		grid-template-columns: auto 1fr auto;
		align-items: center;
		gap: 2rem;
		padding: 0.75rem 1.5rem;
	}

	.brand {
		font-family: var(--font-sans);
		font-size: 0.95rem;
		font-weight: 600;
		letter-spacing: -0.012em;
		color: var(--color-text-main);
		border: none;
	}
	.brand:hover { color: var(--color-accent); border: none; }

	.nav-desktop {
		display: flex;
		justify-content: center;
		gap: 1.85rem;
	}
	.nav-link {
		font-family: var(--font-sans);
		font-size: 0.88rem;
		font-weight: 500;
		color: var(--color-text-muted);
		border: none;
		padding: 0.4rem 0;
		transition: color 0.15s var(--ease);
	}
	.nav-link:hover { color: var(--color-text-main); border: none; }
	.nav-link.is-active {
		color: var(--color-text-main);
		position: relative;
	}
	.nav-link.is-active::after {
		content: "";
		position: absolute;
		left: 0;
		right: 0;
		bottom: -2px;
		height: 1.5px;
		background: var(--color-accent);
		border-radius: 1px;
	}

	.masthead-controls {
		display: flex;
		gap: 0.25rem;
		align-items: center;
		justify-self: end;
	}
	.icon-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 36px;
		height: 36px;
		background: transparent;
		border: 1px solid transparent;
		border-radius: var(--radius);
		color: var(--color-text-muted);
		cursor: pointer;
		transition: color 0.15s var(--ease), background 0.15s var(--ease), border-color 0.15s var(--ease);
	}
	.icon-btn:hover {
		color: var(--color-text-main);
		background: var(--color-bg-subtle);
	}
	.icon-sun, .icon-moon { display: none; }
	html[data-theme='light'] .icon-sun, html:not([data-theme='dark']) .icon-sun { display: block; }
	html[data-theme='dark'] .icon-moon { display: block; }

	.menu-only { display: none; }

	.mobile-menu {
		display: none;
		flex-direction: column;
		padding: 0.5rem 1.5rem 1rem;
		border-bottom: 1px solid var(--color-border);
		background: var(--color-bg-mobile-menu);
	}
	.mobile-menu[open] { display: flex; }
	.mobile-link {
		font-family: var(--font-sans);
		font-size: 0.95rem;
		color: var(--color-text-muted);
		padding: 0.7rem 0;
		border: none;
		border-bottom: 1px solid var(--color-border-soft);
	}
	.mobile-link.is-active { color: var(--color-text-main); }
	.mobile-link:last-child { border-bottom: none; }

	@media (max-width: 760px) {
		.masthead-inner {
			grid-template-columns: 1fr auto;
			gap: 1rem;
		}
		.nav-desktop { display: none; }
		.menu-only { display: inline-flex; }
	}
</style>
