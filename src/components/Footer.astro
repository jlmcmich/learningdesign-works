---
const today = new Date();
import { CONTACT, SITE_TITLE, SITE_TAGLINE, SOCIAL_LINKS } from '../consts';
import Search from './Search.astro';
import { url } from '../utils/paths';
---

<footer class="site-footer">
	<div class="footer-inner">
		<div class="footer-grid">
			<div class="footer-block">
				<div class="block-label">Site</div>
				<p class="block-body">
					<strong>{SITE_TITLE}</strong> · {SITE_TAGLINE}<br/>
					{CONTACT.organization}.
				</p>
			</div>

			<div class="footer-block">
				<div class="block-label">Pages</div>
				<ul>
					<li><a href={url('/')}>Home</a></li>
					<li><a href={url('/projects')}>Projects</a></li>
					<li><a href={url('/ai-prompts')}>AI Prompts</a></li>
					<li><a href={url('/talks')}>Talks &amp; Writing</a></li>
				</ul>
			</div>

			<div class="footer-block">
				<div class="block-label">Connect</div>
				<ul>
					{SOCIAL_LINKS.map((link) => (
						<li>
							<a href={link.href} target="_blank" rel="noopener noreferrer">
								{link.label} <span class="ext" aria-hidden="true">→</span>
							</a>
						</li>
					))}
				</ul>
			</div>
		</div>

		<div class="footer-base">
			<div>© {today.getFullYear()} {SITE_TITLE}.</div>
			<div>Built with Astro.</div>
		</div>
	</div>
</footer>

<Search />

<style>
	.site-footer {
		margin-top: 6rem;
		padding: 3rem 0 2rem;
		border-top: 1px solid var(--color-border);
		font-family: var(--font-sans);
		color: var(--color-text-muted);
	}
	.footer-inner {
		max-width: 1100px;
		margin: 0 auto;
		padding: 0 1.5rem;
	}
	.footer-grid {
		display: grid;
		grid-template-columns: minmax(0, 2fr) minmax(0, 1fr) minmax(0, 1fr);
		gap: 3rem;
		padding-bottom: 2.5rem;
		border-bottom: 1px solid var(--color-border);
		align-items: start;
	}
	.footer-block { min-width: 0; }
	.footer-block ul,
	.footer-block ul li {
		list-style: none !important;
		list-style-type: none !important;
	}
	.footer-block ul {
		padding-left: 0;
		margin-left: 0;
	}
	.block-label {
		font-family: var(--font-mono);
		font-size: 0.72rem;
		color: var(--color-text-faint);
		margin-bottom: 0.75rem;
		font-weight: 500;
	}
	.block-body {
		margin: 0;
		font-size: 0.92rem;
		line-height: 1.65;
		color: var(--color-text-muted);
	}
	.block-body strong {
		color: var(--color-text-main);
		font-weight: 600;
	}
	.footer-block ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.footer-block li {
		margin-bottom: 0.4rem;
		font-size: 0.92rem;
	}
	.footer-block a {
		color: var(--color-text-muted);
		border: none;
	}
	.footer-block a:hover {
		color: var(--color-accent);
		border: none;
	}
	.footer-block .ext {
		color: var(--color-text-faint);
		margin-left: 0.15rem;
	}

	.footer-base {
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		padding-top: 1.5rem;
		font-family: var(--font-mono);
		font-size: 0.75rem;
		color: var(--color-text-faint);
	}

	@media (max-width: 600px) {
		.footer-grid {
			grid-template-columns: 1fr;
			gap: 2rem;
		}
		.footer-base {
			flex-direction: column;
			gap: 0.4rem;
		}
	}
</style>
